{
  "name": "No Algorithms by WarreTh",
  "author": "WarreTh",
  "manifest_version": 3,
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "no-algorithms@example.com"
    }
  },
  "description": "Removes algorithmic feeds from websites. No toggles.",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.instagram.com/*"],
      "js": ["dist/main.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["sites/youtube/style.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "css": ["sites/instagram/style.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["sites/*", "sites/**/*"],
    "matches": ["<all_urls>"]
  }]
}
